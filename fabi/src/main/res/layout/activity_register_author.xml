<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".controleur.activity.AddBookActivity">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_marginTop="50dp"
            android:id="@+id/relative_layout_activity_declaration_img"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="25dp"
            >
            <ImageView
                android:id="@+id/image_view_activity_add_book_cover"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:src="@drawable/img_add_cover"
                android:contentDescription="@string/todo" />
        </LinearLayout>
        <LinearLayout
            android:layout_below="@id/relative_layout_activity_declaration_img"
            android:id="@+id/linear_layout_activity_declaration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginBottom="40dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titre"
                android:textSize="@dimen/size_title"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:layout_marginStart="30dp"
                android:textColor="@color/black"/>
            <EditText
                android:id="@+id/edit_text_activity_register_author_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:backgroundTint="@color/purple_200"
                android:layout_marginEnd="25dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/apple1"
                android:hint="Saisir le title"
                android:inputType="textMultiLine"
                android:paddingBottom="15dp"
                android:paddingTop="15dp"
                android:scrollbars="vertical"
                android:autofillHints="" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:layout_marginTop="10dp"
                android:textSize="@dimen/size_title"
                android:textStyle="bold"
                android:layout_marginStart="30dp"
                android:textColor="@color/black"/>
            <EditText
                android:id="@+id/edit_text_activity_register_author_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:backgroundTint="@color/purple_200"
                android:layout_marginEnd="25dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/apple1"
                android:hint="Saisir la description"
                android:inputType="textMultiLine"
                android:paddingBottom="15dp"
                android:paddingTop="15dp"
                android:scrollbars="vertical"
                android:autofillHints="" />
            <LinearLayout
                style="@style/match_wrap"
                android:layout_marginEnd="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="25dp"
                >
                <TextView
                    style="@style/wrap_content_all"
                    android:fontFamily="@font/apple1"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:text="Cochez cette case si vous avez le format Physique."
                    />
                <CheckBox
                    android:id="@+id/check_box_activity_register_author_is_physique"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>
            <LinearLayout
                style="@style/match_wrap"
                android:layout_marginEnd="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="25dp"
                >
                <TextView
                    style="@style/wrap_content_all"
                    android:fontFamily="@font/apple1"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:text="Le format électronique."
                    />
                <CheckBox
                    android:id="@+id/check_box_activity_register_author_is_pdf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/linear_layout_activity_register_author_setting_pdf"
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <Button
                    android:id="@+id/btnSelectPdf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sélectionner un PDF"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"/>

                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aucun pdf sélectionné"
                    android:textSize="14sp"
                    android:layout_marginStart="10dp"
                    android:padding="16dp"/>
            </LinearLayout>
            <LinearLayout
                style="@style/match_wrap"
                android:layout_marginEnd="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="25dp"
                >
                <TextView
                    style="@style/wrap_content_all"
                    android:fontFamily="@font/apple1"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:text="Le format audio."
                    />
                <CheckBox
                    android:id="@+id/check_box_activity_add_book_is_audio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/linear_layout_activity_add_book_setting_audio"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <Button
                    android:id="@+id/btnSelectAudio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sélectionner un Audio"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"/>

                <TextView
                    android:id="@+id/tvAudioFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aucun audio sélectionné"
                    android:textSize="14sp"
                    android:layout_marginStart="10dp"
                    android:padding="16dp"/>
            </LinearLayout>

            <Spinner
                android:id="@+id/spinner_activity_add_book_cotegory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="25dp"
                android:background="@drawable/forme_white_radius_100dp_border_vert"
                android:fontFamily="sans-serif-smallcaps"

                android:gravity="center"
                android:paddingTop="15dp"
                android:paddingBottom="15dp" />

            <Spinner
                android:id="@+id/spinner_activity_add_book_structure"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="25dp"
                android:layout_marginEnd="20dp"
                android:fontFamily="sans-serif-smallcaps"
                android:gravity="center"
               android:background="@drawable/forme_white_radius_100dp_border_vert"
                android:paddingTop="15dp"
                android:paddingBottom="15dp"/>
            <LinearLayout
                style="@style/match_wrap"
                android:layout_marginEnd="5dp"
                android:layout_marginTop="10dp"
                >
                <CheckBox
                    android:id="@+id/check_box_activity_add_book_engagement"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"/>
                <TextView
                    style="@style/wrap_content_all"
                    android:fontFamily="@font/apple1"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:padding="10dp"
                    android:text="Je certifie que je suis l’auteur ou que je détiens les droits de publication de ce livre."
                    />
            </LinearLayout>
            <TextView
                android:id="@+id/text_view_activity_add_book_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text=""
                android:textColor="@color/rouge"
                android:textSize="@dimen/size_sub_title" />
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:layout_marginEnd="20dp"
                >
                <TextView
                    android:id="@+id/text_view_activity_suggestion_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"
                    android:text=""
                    android:textColor="@color/rouge"
                    android:textSize="@dimen/size_sub_title" />

                <ProgressBar
                    android:id="@+id/progress_bar_activity_add_book_whait"
                    style="@android:style/Widget.Holo.ProgressBar.Small"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_centerInParent="true"
                    android:layout_marginStart="40dp"
                    android:layout_centerVertical="true"
                    android:elevation="5dp"
                    android:padding="20dp"
                    android:visibility="invisible"
                    android:progressDrawable="@drawable/form_circular_bar_connexion" />
                <Button
                    android:id="@+id/button_activity_add_book"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:background="@drawable/forme_purple2_200_radius_10dp"
                    android:textAllCaps="false"
                    android:text="Demander à publier"/>
            </RelativeLayout>
        </LinearLayout>
    </RelativeLayout>
</androidx.core.widget.NestedScrollView>