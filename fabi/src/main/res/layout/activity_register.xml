<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context="com.ninotech.fabi.controleur.activity.LoginActivity">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_marginTop="10dp"
            android:id="@+id/relative_layout_activity_register_img"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="25dp"
            >
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="250dp"
                android:src="@drawable/img_register"
                android:contentDescription="@string/todo" />
        </RelativeLayout>
        <EditText
            android:id="@+id/edit_text_activity_register_name"
            android:hint=" Entrer votre nom"
            android:layout_below="@id/relative_layout_activity_register_img"
            android:inputType="text"
            style="@style/activity_login_edit_text_number"
            android:autofillHints="" />
        <EditText
            android:id="@+id/edit_text_activity_register_first_name"
            android:hint=" Entrer votre prénom"
            android:layout_below="@id/edit_text_activity_register_name"
            android:inputType="text"
            style="@style/activity_register_edit_text_firstname"
            android:autofillHints="" />
        <EditText
            android:id="@+id/edit_text_activity_register_id_number"
            android:hint=" Entrer votre numéro"
            android:layout_below="@id/edit_text_activity_register_first_name"
            android:inputType="number"
            android:importantForAutofill="no"
            style="@style/activity_register_edit_text_number"
            android:autofillHints="" />
        <EditText
            android:id="@+id/edit_text_activity_register_email"
            android:hint=" exemple@gmail.com"
            android:layout_below="@id/edit_text_activity_register_id_number"
            android:inputType="textEmailAddress"
            style="@style/activity_register_edit_text_email"
            android:autofillHints="" />
        <EditText
            android:id="@+id/edit_text_activity_register_password"
            android:hint="@string/edit_text_hint_password"
            android:layout_below="@id/edit_text_activity_register_email"
            android:inputType="textPassword"
            style="@style/activity_login_edit_text_password"
            android:autofillHints="" />
        <EditText
            android:id="@+id/edit_text_activity_register_password_confirm"
            android:hint="@string/edit_text_hint_password_confirm"
            android:layout_below="@id/edit_text_activity_register_password"
            android:inputType="textPassword"
            style="@style/activity_register_edit_text_password_confirm"
            android:autofillHints="" />
        <Spinner
            android:id="@+id/spinner_activity_register_profession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_below="@id/edit_text_activity_register_password_confirm"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="25dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="sans-serif-smallcaps"
            android:gravity="center"
            android:backgroundTint="@color/purple_200"
            android:padding="10dp"/>
        <TextView
            android:id="@+id/text_view_activity_register_error"
            style="@style/text_view_error_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/spinner_activity_register_profession"
            android:layout_marginBottom="31dp" />
        <RelativeLayout
            android:id="@+id/relative_layout_activity_register_connection"
            style="@style/wrap_content_all"
            android:layout_below="@+id/text_view_activity_register_error"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:layout_marginBottom="20dp"
            >

            <ProgressBar
                android:id="@+id/progress_bar_activity_register_connection"
                android:layout_alignStart="@id/button_activity_register_connection"
                style="@style/progress_bar_connection"/>

            <Button
                android:id="@+id/button_activity_register_connection"
                style="@style/button_connexion" />
        </RelativeLayout>
        <TextView
            android:id="@+id/text_view_activity_register_login"
            android:layout_below="@id/relative_layout_activity_register_connection"
            android:layout_marginBottom="10dp"
            android:layout_centerHorizontal="true"
            android:layout_gravity="center_horizontal"
            style="@style/text_view_pass_login_register" />
    </RelativeLayout>
</androidx.core.widget.NestedScrollView>