<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.ninotech.fabi.controleur.activity.AuthorActivity">

    <RelativeLayout
        android:layout_margin="10dp"
        android:id="@+id/relative_layout_activity_author_profile"
        android:layout_width="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_height="wrap_content"
        >
        <ImageView
            android:id="@+id/image_view_author_activity_profile"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerHorizontal="true"
            android:src="@drawable/user"
            />
        <LinearLayout
            android:id="@+id/linear_layout_activity_author_profile"
            android:layout_margin="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/image_view_author_activity_profile"
            android:layout_centerHorizontal="true"
            android:orientation="vertical"
            >
            <TextView
                android:id="@+id/text_view_activity_author_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="20dp"/>
            <TextView
                android:id="@+id/text_view_activity_author_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="2023-2024-Master-1-IFA"/>

        </LinearLayout>
        <View
            android:id="@+id/view_fragment_library_1"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/separator"
            android:layout_below="@+id/linear_layout_activity_author_profile"
            />
        <TextView
            android:id="@+id/text_view_fragment_library_recent_read_book"
            style="@style/wrap_content_all"
            android:layout_below="@+id/view_fragment_library_1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="20dp"

            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:text="Mes Livres"
            android:textStyle="bold"
            android:textSize="@dimen/size_title" />

        <!-- TODO: Update blank fragment layout -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_electronic_fragment_recent"
            android:layout_below="@+id/text_view_fragment_library_recent_read_book"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <View
            android:id="@+id/view_fragment_library_2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/separator"
            android:layout_below="@+id/recycler_view_electronic_fragment_recent"
            />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_electronic_fragment_media"
            android:layout_below="@+id/view_fragment_library_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"/>
    </RelativeLayout>
</androidx.core.widget.NestedScrollView>