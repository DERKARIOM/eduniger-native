<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/forme_white_radius_10dp"
    android:padding="20dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="20dp">
        <ImageView
            android:id="@+id/image_view_dialog_simple_ok_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/vector_emoji_success" />
        <TextView
            android:id="@+id/text_view_dialog_simple_ok_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Succès"
            android:textSize="25dp"
            android:textColor="@color/purple_200"
            android:fontFamily="@font/linux2"
            />
    </LinearLayout>
    <TextView
        android:id="@+id/text_view_dialog_simple_ok_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Merci beaucoup pour votre suggestion ! Nous apprécions vraiment que vous preniez le temps de nous faire part de vos idées pour améliorer fastpv"
        android:layout_margin="10dp"
        android:gravity="center"
        android:layout_gravity="center"
        android:fontFamily="@font/linux2"
        android:textColor="@color/black2"
        android:textSize="15dp"
        />
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="end"
        android:layout_margin="10dp"
        >
        <TextView
            android:id="@+id/text_view_dialog_simple_ok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OK"
            android:layout_margin="10dp"
            android:textColor="@color/purple_200"
            android:fontFamily="@font/linux2"
            android:textSize="20dp"
            />
    </LinearLayout>
</LinearLayout>