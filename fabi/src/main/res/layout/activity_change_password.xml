<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.ninotech.fabi.controleur.activity.ChangePasswordActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/edit_text_activity_change_password_id_number"
        android:layout_alignParentTop="true"
        android:background="@android:color/transparent"
        android:elevation="10dp"
        android:layout_marginBottom="60dp">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/forget_password"/>
    </RelativeLayout>

    <EditText
        android:id="@+id/edit_text_activity_change_password_id_number"
        android:layout_above="@id/edit_text_activity_change_password_mail"
        android:hint=" Entre votre numéro"
        android:inputType="number"
        style="@style/activity_login_edit_text_number"
        android:autofillHints="" />

    <EditText
        android:id="@+id/edit_text_activity_change_password_mail"
        android:layout_above="@id/edit_text_activity_change_password_password"
        android:hint=" exemple@gmail.com"
        android:inputType="textEmailAddress"
        style="@style/activity_register_edit_text_email"
        tools:ignore="TextFields"
        android:autofillHints="" />

    <EditText
        android:id="@+id/edit_text_activity_change_password_password"
        android:layout_above="@id/edit_text_activity_change_password_confirm_password"
        android:hint="@string/password_new"
        android:inputType="textPassword"
        style="@style/activity_login_edit_text_password"
        android:autofillHints="" />

    <EditText
        android:id="@+id/edit_text_activity_change_password_confirm_password"
        android:layout_above="@+id/text_view_activity_change_password_error"
        android:hint="@string/edit_text_hint_password_confirm"
        android:inputType="textPassword"
        style="@style/activity_register_edit_text_password_confirm"
        android:autofillHints="" />

    <TextView
        android:id="@+id/text_view_activity_change_password_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/relative_layout_change_password_connection"
        style="@style/text_view_error_register" />


    <RelativeLayout
        android:id="@+id/relative_layout_change_password_connection"
        style="@style/wrap_content_all"
        android:layout_above="@id/text_view_activity_change_password_change_mail"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="20dp"
        >

        <ProgressBar
            android:id="@+id/progress_bar_change_password_connection"
            android:layout_alignStart="@id/button_activity_change_password_connection"
            style="@style/progress_bar_connection"/>

        <Button
            android:id="@+id/button_activity_change_password_connection"
            style="@style/button_connexion" />
    </RelativeLayout>

    <TextView
        android:id="@+id/text_view_activity_change_password_change_mail"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="10dp"
        android:text="Version : 3.1.2"
        android:textColor="@color/purple_200"
        style="@style/text_view_pass_login_register"/>
</RelativeLayout>