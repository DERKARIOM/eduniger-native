<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context="com.fabi.Controleur.EmpreinteActivity">
    <RelativeLayout
        android:id="@+id/block_login"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_above="@id/Edigitale"
        android:layout_alignParentTop="true"
        android:background="@drawable/bbock"
        android:elevation="10dp"
        android:layout_marginBottom="140dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:padding="5dp">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="50dp"
                android:src="@drawable/lock"/>
            <TextView
                android:id="@+id/TextConnect"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="FAST-PV Verrouillé"
                android:textColor="@color/white"
                android:textSize="20dp" />
        </LinearLayout>
    </RelativeLayout>
    <ImageView
        android:id="@+id/Edigitale"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/digitale"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="50dp"
        android:layout_above="@id/messageDigitale"
        />
    <TextView
        android:id="@+id/messageDigitale"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/TextAideDigitale"
        android:layout_marginBottom="160dp"
        android:layout_centerHorizontal="true"
        android:text="Touchez le capteur d'empreinte"
        />
    <TextView
        android:id="@+id/TextAideDigitale"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:text="Besoin d'aide"
        android:textSize="15dp" />

</RelativeLayout>