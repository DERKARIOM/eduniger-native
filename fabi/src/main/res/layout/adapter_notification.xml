<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center">
    <LinearLayout
        android:id="@+id/bNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
       android:background="@drawable/forme_white2_radius_10dp"
        android:elevation="2dp"
        android:layout_margin="10dp"
        android:padding="8dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/notifTitre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:fontFamily="sans-serif-smallcaps"
            android:text="Vous"
            android:textSize="12dp"
            android:textColor="@color/white"
            />
        <ImageView
            android:id="@+id/image_view_adapter_notification"
            android:layout_width="match_parent"
            android:layout_height="550dp"
            android:layout_marginTop="-25dp"
            android:src="@drawable/open"/>
        <TextView
            android:id="@+id/notifMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="l' exament de syteme"
            android:layout_marginTop="-5dp"
            android:layout_marginBottom="10dp"
            android:textColor="@color/black2"
            android:textSize="17dp" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/notifDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="10:50"
                android:textSize="8dp"
                android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>