<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.fabi.controleur.activity.LivreActivity">
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:layout_marginTop="20dp"
        android:id="@+id/BtoolbarCategorie">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:menu="@menu/menu_home"
            app:logo="@drawable/vector_back"
            android:layout_centerVertical="true"
            app:titleMarginStart="15dp"
            android:paddingStart="20dp"
            app:titleTextColor="@color/black3"
            android:layout_alignParentTop="true"
            app:titleTextAppearance="@style/CustoTollbar"
            />
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/toolbar2">
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <RelativeLayout
                    android:id="@+id/bLivre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="10dp"
                    >
                    <ImageView
                        android:id="@+id/couverture_livre2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_marginBottom="10dp"
                        android:elevation="2dp"
                        android:src="@drawable/img_default_livre" />
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@id/couverture_livre2">

                        <TextView
                            android:id="@+id/title_livre2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:layout_marginTop="5dp"
                            android:layout_marginEnd="5dp"
                            android:layout_marginBottom="5dp"
                            android:text="Femmes du silence"
                            android:textColor="@color/black"
                            android:textSize="20dp" />

                        <TextView
                            android:id="@+id/categorie_livre2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/title_livre2"
                            android:layout_marginStart="5dp"
                            android:layout_marginTop="5dp"
                            android:layout_marginEnd="5dp"
                            android:layout_marginBottom="5dp"
                            android:text="Literature"
                            android:textSize="15dp" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/categorie_livre2">
                            <LinearLayout
                                android:id="@+id/like"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="10dp">
                                <ImageView
                                    android:id="@+id/ico1"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:elevation="10dp"
                                    android:src="@drawable/vector_black3_off_like"/>
                                <TextView
                                    android:id="@+id/nbr_like"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="3dp"
                                    android:text="0"
                                    android:gravity="center_vertical"
                                    android:textSize="10dp"
                                    android:layout_gravity="center_vertical"
                                    android:src="@drawable/vector_black3_off_like"/>
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/nolike"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="10dp">
                                <ImageView
                                    android:id="@+id/ico2"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:elevation="10dp"
                                    android:src="@drawable/vector_black3_off_nolike"/>
                                <TextView
                                    android:id="@+id/nbr_nolike"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="3dp"
                                    android:text="0"
                                    android:gravity="center_vertical"
                                    android:textSize="10dp"
                                    android:layout_gravity="center_vertical" />
                            </LinearLayout>
                            <LinearLayout
                                android:id="@+id/notification"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                android:layout_gravity="center">
                                <ImageView
                                    android:id="@+id/ico3"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:elevation="10dp"
                                    android:src="@drawable/vector_black3_notifications"/>
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>
                </RelativeLayout>
                <LinearLayout
                    android:id="@+id/bReservation"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/bLivre"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_marginBottom="10dp"
                            android:text="Reservation de ce livre"
                            android:textColor="@color/black"
                            android:textSize="20dp" />
                        <Spinner
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            />
                    </RelativeLayout>
                    <Button
                        android:id="@+id/btt_reservation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Réservation  du livre "
                        android:textAllCaps="false"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        app:icon="@drawable/vector_black3_pysique"
                        android:textSize="15dp"
                        android:backgroundTint="@color/sombre"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/bAudio"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/bReservation"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Format Audio"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:layout_margin="10dp"/>
                            <Spinner
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                />
                    </RelativeLayout>
                    <LinearLayout
                        android:id="@+id/media"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <ImageView
                                android:id="@+id/paly"
                                android:layout_margin="10dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/vector_black3_plause"
                                />
                            <ImageView
                                android:id="@+id/stop"
                                android:layout_marginStart="3dp"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp"
                                android:layout_marginEnd="3dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/vector_black3_stop"
                                />
                            <TextView
                                android:id="@+id/heurInit"
                                android:layout_marginStart="8dp"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp"
                                android:layout_gravity="center_vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00"
                                />
                            <SeekBar
                                android:id="@+id/seekbar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_margin="10dp"
                                android:progress="100"/>
                        </LinearLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recylerAudio2"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            />
                    </LinearLayout>
                    <Button
                        android:id="@+id/btt_audio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Format audio"
                        android:textAllCaps="false"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        app:icon="@drawable/vector_white_download"
                        android:textSize="15dp"
                        android:backgroundTint="@color/sombre"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/bPDF"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/bAudio"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_marginBottom="10dp"
                            android:text="Format Electronique"
                            android:textColor="@color/black"
                            android:textSize="20dp" />
                        <Spinner
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            />
                    </RelativeLayout>
                    <Button
                        android:id="@+id/btt_pdf_ouvrir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ouvrir"
                        android:textAllCaps="false"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        app:icon="@drawable/vector_black3_pdf"
                        android:textSize="15dp"
                        android:backgroundTint="@color/sombre"/>
                    <Button
                        android:id="@+id/btt_pdf"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Format PDF"
                        android:textAllCaps="false"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        app:icon="@drawable/vector_white_download"
                        android:textSize="15dp"
                        android:backgroundTint="@color/sombre"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/apropos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/bPDF"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_marginBottom="10dp"
                            android:text="A propos du livre"
                            android:textColor="@color/black"
                            android:textSize="20dp" />
                        <Spinner
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            />
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/desc_livre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ce Livre est un chef-d'œuvre captivant qui explore les profondeurs de l'âme féminine avec une grâce poignante. À travers des personnages complexes et des récits riches, l'auteur tisse une histoire émouvante de courage, de résilience et de découverte de soi. Chaque page résonne avec une puissante authenticité, nous plongeant dans un monde où les silences parlent plus fort que les mots. Une lecture inoubliable qui laisse une empreinte profonde dans le cœur et l'esprit, révélant la force incommensurable des femmes face à l'adversité."
                        android:justificationMode="inter_word"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:textColor="@color/black2"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/Commenatire"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/apropos"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_marginBottom="10dp"
                            android:text="Commentaires"
                            android:textColor="@color/black"
                            android:textSize="20dp" />
                        <Spinner
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            />
                    </RelativeLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recylerCommentaire"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        />
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        >
                        <EditText
                            android:id="@+id/messageCommentaire"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/forme_white_radius_10dp"
                            android:hint=" Ajouter votre Commentaire"
                            android:layout_centerVertical="true"
                            android:padding="5dp"
                            android:layout_marginEnd="50dp"/>
                        <ImageView
                            android:id="@+id/addCommentaire"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/vector_black3_add"
                            android:layout_centerVertical="true"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/Commenatire"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_marginBottom="10dp"
                            android:text="Les livres similaires"
                            android:textColor="@color/black"
                            android:textSize="20dp" />
                        <Spinner
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            />
                    </RelativeLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recylerSimilaire"
                        android:layout_margin="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        />
                </LinearLayout>
            </RelativeLayout>
        </androidx.core.widget.NestedScrollView>
    </RelativeLayout>
</RelativeLayout>