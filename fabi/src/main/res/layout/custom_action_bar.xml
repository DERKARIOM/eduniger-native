<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- Titre de l'Action Bar -->
    <TextView
        android:layout_gravity="center"
        android:id="@+id/action_bar_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/black"
        android:textSize="@dimen/size_title"
        android:text="Category" />
    <EditText
        android:id="@+id/edit_text_custom_action_bar_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/forme_white_radius_10dp"
        android:elevation="1dp"
        android:visibility="gone"
        android:layout_alignParentEnd="true"
        android:layout_gravity="center"
        android:layout_marginEnd="100dp"
        android:hint="@string/find_book"
        android:drawableStart="?android:attr/actionModeWebSearchDrawable"
        android:drawableEnd="@drawable/vector_black3_micro"
        android:inputType="text"
        android:layout_centerVertical="true"
        android:padding="5dp"
        android:focusable="false"
        android:selectAllOnFocus="false" />

    <!-- Vous pouvez ajouter d'autres éléments ici, comme des boutons d'action -->

</LinearLayout>