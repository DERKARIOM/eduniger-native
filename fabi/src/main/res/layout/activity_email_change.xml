<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context="com.ninotech.fabi.controleur.activity.EmailChangeActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_above="@+id/EditMatricule4"
        android:layout_marginBottom="40dp"
        android:background="@android:color/transparent"
        android:elevation="10dp"
        android:layout_alignParentTop="true">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/img_regester"/>

    </RelativeLayout>

    <EditText
        android:id="@+id/EditMatricule4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/EditPasse4"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/forme_white_radius_10dp"
        android:elevation="10dp"
        android:hint="  Votre matricule ?"
        android:drawableStart="@drawable/vector_black3_identify"
        android:inputType="number"
        android:padding="10dp" />

    <EditText
        android:id="@+id/EditPasse4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/EditMail3"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/forme_white_radius_10dp"
        android:elevation="10dp"
        android:hint="  Votre mot de passe ?"
        android:drawableStart="@drawable/vector_black3_password"
        android:inputType="text"
        android:padding="10dp" />

    <EditText
        android:id="@+id/EditMail3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/TextErr4"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/forme_white_radius_10dp"
        android:elevation="10dp"
        android:hint="  Nouveau adresse email"
        android:drawableStart="@drawable/vector_black3_email"
        android:inputType="textEmailAddress"
        android:padding="10dp" />

    <TextView
        android:id="@+id/TextErr4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/ButtonConnect4"
        android:layout_centerInParent="true"
        android:layout_marginBottom="30dp"
        android:text=""
        android:textColor="@color/rouge"
        android:textSize="12dp" />


    <Button
        android:id="@+id/ButtonConnect4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/changepasse"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/forme_purple_200_radius_10dp"
        android:padding="10dp"
        android:text="Connexion" />

    <TextView
        android:id="@+id/changepasse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:padding="10dp"
        android:text="Changer votre mot de passe"
        android:textColor="@color/purple_200"
        android:textSize="15dp" />
</RelativeLayout>