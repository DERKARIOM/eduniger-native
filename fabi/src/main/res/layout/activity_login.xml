<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="false"
    tools:context="com.ninotech.fabi.controleur.activity.LoginActivity">

    <!-- Fond avec gradient -->
    <View
        android:id="@+id/backgroundView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        style="@style/activity_login_background"/>

    <!-- Ici tu mets tes autres éléments d'UI (EditText, Button, etc.) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <RelativeLayout
                android:layout_marginTop="10dp"
                android:id="@+id/relative_layout_activity_register_img"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                >
                <ImageView
                    android:id="@+id/activity_login_image_view"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="28dp"
                    android:layout_marginBottom="5dp"
                    android:src="@drawable/img_login_edu_niger"
                    android:contentDescription="@string/todo" />
            </RelativeLayout>
            <LinearLayout
                android:id="@+id/activity_login_linear_layout_number"
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_below="@id/relative_layout_activity_register_img"
                style="@style/activity_login_edit_text_number"
                android:padding="6dp">

                <!-- Sélecteur de code pays -->
                <com.hbb20.CountryCodePicker
                    android:id="@+id/countryCodePicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/activity_login_code_payer_text_color"
                    app:ccp_showFlag="true"
                    app:ccp_showFullName="false"
                    app:ccp_showNameCode="false"
                    app:ccp_defaultNameCode="NE" /> <!-- NE = Niger -->

                <!-- Zone de saisie numéro -->
                <EditText
                    android:id="@+id/edit_text_login_id_number"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="phone"
                    style="@style/activity_login_color_hint"
                    android:hint="Entrer votre numéro"
                    android:padding="8dp"
                    android:background="@null"/>
            </LinearLayout>
            <EditText
                android:id="@+id/edit_text_login_password"
                android:hint=" Votre mot de passe ?"
                android:layout_below="@id/activity_login_linear_layout_number"
                android:inputType="textPassword"
                style="@style/activity_login_edit_text_password"
                android:autofillHints="" />
            <TextView
                android:id="@+id/text_view_activity_login_forget_password"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:layout_below="@id/edit_text_login_password"
                android:layout_alignParentEnd="true"
                android:padding="10dp"
                android:layout_marginEnd="25dp"
                android:layout_marginTop="-20dp"
                android:textSize="@dimen/size_title"
                android:textStyle="bold"
                android:text="Mot de passe oublié ?"
                />
            <TextView
                android:id="@+id/text_view_login_error"
                android:layout_below="@id/edit_text_login_password"
                style="@style/text_view_error_register"
                android:layout_marginTop="20dp"/>
            <RelativeLayout
                android:id="@+id/relative_layout_activity_register_connection"
                style="@style/wrap_content_all"
                android:layout_below="@+id/text_view_login_error"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:layout_marginBottom="20dp"
                >

                <ProgressBar
                    android:id="@+id/progress_bar_register_connection"
                    android:layout_alignStart="@id/button_login_connection"
                    style="@style/progress_bar_connection"/>

                <Button
                    android:id="@+id/button_login_connection"
                    android:textAllCaps="false"
                    style="@style/button_connexion" />
            </RelativeLayout>
            <LinearLayout
                android:id="@+id/linear_layout_activity_login_google"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:elevation="10dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="30dp"
                style="@style/activity_login_pass_google"
                android:layout_below="@id/relative_layout_activity_register_connection"

                >
                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/img_google"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continuer avec Google"
                    android:textSize="16sp"
                    android:layout_marginStart="10dp"
                    android:textStyle="bold"
                    android:layout_gravity="center"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/linear_layout_activity_login_create_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="10dp"
                android:layout_below="@id/linear_layout_activity_login_google"
                android:layout_gravity="center_horizontal"
                >
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"

                    android:textSize="@dimen/size_title"
                    android:text="Vous n'avez pas de compte ?"
                    />
                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:id="@+id/text_view_login_pass_register"
                    android:padding="10dp"
                    android:textSize="@dimen/size_title"
                    android:textStyle="bold"
                    android:text="Céer un compte"
                    />
            </LinearLayout>
            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:padding="20dp"
                android:textSize="@dimen/size_title"
                android:text="Version : 3.1.2"
                android:layout_below="@id/linear_layout_activity_login_create_account"
                android:layout_centerHorizontal="true"
                android:textColor="@color/purple_200"
                />
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>