<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp">

    <ImageView
        android:id="@+id/couverture_livre"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:elevation="2dp"
        android:src="@drawable/img_default_livre"
        android:contentDescription="@string/todo" />
    <RelativeLayout
        android:id="@+id/info_livre"
        style="@style/wrap_content_all"
        android:layout_toEndOf="@+id/couverture_livre"
        android:layout_centerVertical="true">

        <TextView
            android:id="@+id/title_livre"
            style="@style/wrap_content_all"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="5dp"
            android:text="@string/title_livre"
            android:textColor="@color/black2"
            android:textSize="@dimen/size_title"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/categorie_livre"
            style="@style/wrap_content_all"
            android:layout_margin="5dp"
            android:layout_below="@id/title_livre"
            android:text="@string/book_category"
            android:textSize="@dimen/size_sub_title"/>
        <LinearLayout
            style="@style/wrap_content_all"
            android:layout_below="@id/categorie_livre">
            <ImageView
                android:id="@+id/ico_pysique"
                android:src="@drawable/vector_black3_pysique"
                style="@style/icon_format"
                android:contentDescription="@string/todo" />
            <ImageView
                android:id="@+id/ico_pdf"
                style="@style/icon_format"
                android:src="@drawable/vector_black3_pdf"
                android:contentDescription="@string/todo" />
            <ImageView
                android:id="@+id/ico_audio"
                style="@style/icon_format"
                android:src="@drawable/vector_audio"
                android:contentDescription="@string/todo" />
            <LinearLayout
                android:id="@+id/like"
                style="@style/wrap_content_all"
                android:layout_margin="5dp"
                android:orientation="horizontal"
                tools:ignore="UseCompoundDrawables">
                <ImageView
                    android:id="@+id/ico1"
                    style="@style/icon_subcribe"
                    android:src="@drawable/vector_black3_off_like"
                    android:contentDescription="@string/todo" />
                <TextView
                    android:id="@+id/nbr_like"
                    style="@style/icon_subcribe_text_view"
                    android:src="@drawable/vector_black3_off_like"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/vue"
                style="@style/wrap_content_all"
                android:layout_margin="5dp"
                tools:ignore="UseCompoundDrawables">
                <ImageView
                    android:id="@+id/ico2"
                    style="@style/icon_subcribe"
                    android:src="@drawable/vector_black3_vue"
                    android:contentDescription="@string/todo" />
                <TextView
                    android:id="@+id/nbr_vue"
                    style="@style/icon_subcribe_text_view"
                    android:src="@drawable/vector_black3_off_like"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>