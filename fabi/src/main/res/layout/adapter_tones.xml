<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/itemSon"
             style="@style/match_wrap"
             android:layout_marginStart="10dp"
             android:layout_marginEnd="10dp">

    <TextView
        android:id="@+id/text_view_adapter_tones_number"
        style="@style/wrap_content_all"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:text="1"
        android:textSize="@dimen/size_sub_title"/>
    <TextView
        android:id="@+id/text_view_adapter_tones_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/text_view_adapter_tones_number"
        android:layout_margin="10dp"
        android:textSize="@dimen/size_title"
        android:layout_centerVertical="true"
        android:text="@string/title_tones"
        tools:ignore="RelativeOverlap" />
    <ImageView
       style="@style/wrap_content_all"
        android:src="@drawable/vector_black3_download"
        android:layout_margin="10dp"
        android:layout_alignParentEnd="true"
        android:contentDescription="@string/todo" />
</RelativeLayout>