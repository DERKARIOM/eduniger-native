<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.fabi.controleur.activity.NotificationActivity">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/menu_notification"
        app:logo="@drawable/vector_back"
        app:title="Notification"
        android:layout_centerVertical="true"
        app:titleMarginStart="15dp"
        android:paddingStart="20dp"
        app:titleTextColor="@color/black3"
        android:layout_alignParentTop="true"
        app:titleTextAppearance="@style/CustoTollbar"
        />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyler2"
        android:layout_width="match_parent"
        android:layout_below="@id/toolbar4"
        android:layout_height="match_parent"
        />
  </RelativeLayout>