<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/bUe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/whiteSombre"
        android:padding="10dp"
        >
            <TextView
                android:id="@+id/UEStatisque"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Algorithme"
                android:fontFamily="@font/timeslight"
                android:textSize="20dp"
                android:layout_centerInParent="true"/>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/bLable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/bUe"
        android:layout_margin="10dp"
        android:padding="10dp">

        <TextView
            android:id="@+id/nbrCopie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:text="Nombre de copie : " />

        <TextView
            android:id="@+id/nbrMoy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/nbrCopie"
            android:layout_margin="5dp"
            android:text="Nombre Moyenne : " />

        <TextView
            android:id="@+id/maxNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/nbrMoy"
            android:layout_margin="5dp"
            android:text="Max Note : " />

        <TextView
            android:id="@+id/minNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/maxNote"
            android:layout_margin="5dp"
            android:text="Min Note : " />
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/bValeur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/bUe"
        android:layout_margin="10dp"
        android:layout_toRightOf="@id/bLable"
        android:padding="10dp">

        <TextView
            android:id="@+id/nbrCopieV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="5dp"
            android:text="6"
            android:textColor="@color/purple_200" />

        <TextView
            android:id="@+id/nbrMoyV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/nbrCopieV"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="5dp"
            android:text="3"
            android:textColor="@color/purple_200" />
        <TextView
            android:id="@+id/maxNoteV"
            android:layout_margin="5dp"
            android:layout_below="@id/nbrMoyV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="18/20"
            android:textColor="@color/purple_200"
            />
        <TextView
            android:id="@+id/minNoteV"
            android:layout_margin="5dp"
            android:layout_below="@id/maxNoteV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01/20"
            android:textColor="@color/purple_200"
            />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/bPorgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/bUe"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_margin="30dp"
        android:padding="10dp">

        <ProgressBar
            android:id="@+id/progressMoySect"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerInParent="true"
            android:indeterminate="false"
            android:progress="50"
            android:progressDrawable="@drawable/circulaire_bar" />

        <TextView
            android:id="@+id/moySect"
            style="@style/semeste"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="50%" />
    </RelativeLayout>



</RelativeLayout>