<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    >
    <RelativeLayout
        android:id="@+id/relative_adapter_no_connection_wait"
        android:layout_width="wrap_content"
        android:padding="10dp"
        android:layout_height="wrap_content"
        >
        <ProgressBar
            android:id="@+id/progress_bar_adapter_no_connection"
            android:layout_centerInParent="true"
            android:visibility="visible"
            android:rotation="180"
            style="@style/progress_bar_try_connection" />
        <ProgressBar
            android:id="@+id/progress_bar_adapter_no_connection2"
            android:layout_centerInParent="true"
            android:visibility="visible"
            style="@style/progress_bar_try_connection2" />
    </RelativeLayout>
    <ImageView
        android:id="@+id/image_view_adapter_no_connection"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:visibility="gone"
        android:src="@drawable/img_no_wifi"/>
    <TextView
        android:id="@+id/text_view_adapter_no_connection_title"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vous êtes hors connexion"
        android:textSize="16sp"
        android:textStyle="bold"/>
    <TextView
        android:id="@+id/text_view_adapter_no_connection_desc"
        android:layout_width="wrap_content"
        android:visibility="gone"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="Vérifiez votre connexion Internet ou continuez en mode hors ligne."
        android:textSize="14sp"
        />
    <LinearLayout
        android:visibility="gone"
        android:id="@+id/linear_layout_adapter_no_connection_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:gravity="center_horizontal"
        >
        <TextView
            android:id="@+id/button_adapter_no_connection_off_line"
            android:layout_width="120dp"
            android:layout_height="35dp"
            android:text="HORS LIGNE"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_margin="10dp"
            android:textSize="14sp"
            style="@style/adapter_no_connection_btt_offline"/>
        <Button
            android:id="@+id/button_adapter_no_connection_re_load"
            android:layout_width="120dp"
            android:layout_height="35dp"
            android:layout_margin="10dp"
            android:paddingTop="-1dp"
            android:gravity="center"
            style="@style/adapter_struture_btt"
            android:background="@drawable/forme_white_100dp"
            android:text="Réessayer"
            />
    </LinearLayout>
</LinearLayout>