<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/forme_white_radius_10dp"
    android:padding="20dp">
    <EditText
        android:id="@+id/notre_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/forme_white_radius_10dp"
        android:elevation="10dp"
        android:maxLength="2"
        android:hint="  Votre note /20..."
        android:drawableStart="@drawable/vector_black3_start"
        android:inputType="number"
        android:textColor="@color/black3"
        android:padding="10dp"
        android:selectAllOnFocus="false" />
    <EditText
        android:id="@+id/notre_observation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
       android:layout_margin="10dp"
        android:textColor="@color/black3"
        android:background="@drawable/forme_white_radius_10dp"
        android:elevation="10dp"
        android:hint="  Observation..."
        android:drawableStart="@drawable/vector_black3_microscopt"
        android:inputType="text"
        android:padding="10dp"
        android:selectAllOnFocus="false" />
    <TextView
        android:id="@+id/err_evaluez"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10dp"
        android:textColor="@color/rouge"
        android:text=""
        android:layout_gravity="center"/>
    <RelativeLayout
        android:id="@+id/BlockButtonConnect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/text_view_login_pass_register"
        android:layout_margin="10dp"
        >

        <ProgressBar
            android:id="@+id/progress_circularEvaluez"
            style="@android:style/Widget.Holo.ProgressBar.Small"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerInParent="true"
            android:layout_marginStart="40dp"
            android:layout_centerVertical="true"
            android:elevation="5dp"
            android:padding="20dp"
            android:visibility="invisible"
            android:progressDrawable="@drawable/forme_circulaire_bar_connexion" />
        <Button
            android:id="@+id/notre_envoi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/forme_purple_200_radius_10dp"
            android:textAllCaps="false"
            android:text="Envoyer" />
    </RelativeLayout>

</LinearLayout>