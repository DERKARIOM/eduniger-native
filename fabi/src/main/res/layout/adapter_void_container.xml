<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center"
    >

    <ImageView
        android:id="@+id/image_view_void_adapter"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:src="@drawable/img_physical"
        android:contentDescription="@string/todo" />
    <TextView
        android:id="@+id/text_view_adapter_container_message"
        android:layout_below="@id/image_view_void_adapter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/size_title"
        android:text="@string/no_book_loand"
       android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:textColor="@color/purple2_200"/>

</RelativeLayout>