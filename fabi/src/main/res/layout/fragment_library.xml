<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.ninotech.fabi.controleur.fragment.LibraryFragment">

    <TextView
        android:id="@+id/text_view_fragment_electronique_recent_book"
        style="@style/wrap_content_all"
        android:layout_alignParentTop="true"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:text="@string/recent_read"
        android:textStyle="bold"
        android:textSize="@dimen/size_title" />

    <!-- TODO: Update blank fragment layout -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_electronic_fragment_recent"
        android:layout_below="@+id/text_view_fragment_electronique_recent_book"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_electronic_fragment_media"
        android:layout_below="@+id/recycler_view_electronic_fragment_recent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"/>

</RelativeLayout>