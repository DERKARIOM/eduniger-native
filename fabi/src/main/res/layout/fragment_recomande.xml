<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Controleur.RecomandeFragment">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/block_welcome"
            android:layout_width="match_parent"
            android:layout_margin="20dp"
            android:backgroundTint="@color/white"
            android:elevation="3dp"
            android:background="@drawable/progretion"
            android:layout_height="wrap_content"
            >
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_margin="10dp"
                android:padding="10dp"
                android:layout_toStartOf="@id/img_welcom">

                <TextView
                    android:id="@+id/text_fabi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="FABI"
                    android:textColor="@color/black"
                    android:textSize="20dp" />
                <TextView
                    android:layout_below="@id/text_fabi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15dp"
                    android:gravity="center"
                    android:text="Plongez dans un mode d' aventures et d' apprentissage sans fin"/>
            </RelativeLayout>
            <ImageView
                android:id="@+id/img_welcom"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:src="@drawable/img1"/>
        </RelativeLayout>
        <!-- TODO: Update blank fragment layout -->
        <androidx.recyclerview.widget.RecyclerView
            android:layout_below="@+id/block_welcome"
            android:id="@+id/recylerClassement"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            />
    </RelativeLayout>

</androidx.core.widget.NestedScrollView>