<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.ninotech.fabi.controleur.activity.FingerPrintActivity">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarEmprint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:logo="@drawable/vector_back"
        app:title="Verrouillage par empreinte digitale"
        android:layout_centerVertical="true"
        app:titleMarginStart="15dp"
        android:paddingStart="20dp"
        app:titleTextColor="@color/black3"
        android:layout_alignParentTop="true"
        app:titleTextAppearance="@style/toolbar"
        />

    <Switch
        android:id="@+id/switch1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/linux2"
        android:showText="false"
       android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="15dp"
        android:text="Déverrouiller avec l'empreinte"
        android:layout_marginBottom="5dp"
        android:layout_below="@+id/toolbarEmprint"
        android:textSize="20dp" />

    <TextView
        android:id="@+id/textEmprinte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lorsque cette option sera activée, vous derez utiliser votre emprinte digitale pour ouvrir fastpv."
        android:layout_marginStart="12dp"
        android:fontFamily="@font/linux2"
        android:textSize="15dp"
        android:layout_marginEnd="10dp"
        android:layout_below="@+id/switch1"
        />

    <RadioGroup
        android:id="@+id/RadioGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:visibility="invisible"
        android:layout_below="@+id/textEmprinte"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/TextAutoLock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verroullage automatique"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="10dp"
            android:textSize="20dp"
            android:fontFamily="@font/linux"
            android:textColor="@color/black"
            />

        <RadioButton
            android:id="@+id/radioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:checked="true"
            android:text="Immédiatement" />

        <RadioButton
            android:layout_marginStart="10dp"
            android:id="@+id/radioButton2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Au bout de 1 minute" />

        <RadioButton
            android:id="@+id/radioButton3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Au bout de 5 minutes" />
    </RadioGroup>

</RelativeLayout>