<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/relative_layout_toolbar_search"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:layout_centerVertical="true"
        app:titleMarginStart="15dp"
        android:paddingStart="20dp"
        app:titleTextColor="@color/black3"
        android:layout_alignParentTop="true"
        app:titleTextAppearance="@style/toolbar"
        app:logo="@drawable/vector_back"
        tools:ignore="RtlSymmetry" />
    <EditText
        android:id="@+id/edit_text_toolbar_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/forme_white_radius_10dp"
        android:elevation="1dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="70dp"
        android:hint="@string/find_book"
        android:drawableEnd="@drawable/vector_black3_micro"
        android:inputType="text"
        android:layout_centerVertical="true"
        android:padding="5dp" />
</RelativeLayout>