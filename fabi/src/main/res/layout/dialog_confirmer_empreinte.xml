<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/block_info_note"
    android:padding="20dp"
    android:orientation="vertical">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirmer l'empreinte"
        android:textColor="@color/black3"
        android:fontFamily="@font/apple1"
        android:textSize="25dp"
        android:gravity="center"/>
    <ImageView
        android:id="@+id/EdigitaleConfirme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/digitale"
        android:layout_marginTop="25dp"
        android:layout_marginBottom="25dp"
        />
    <TextView
        android:id="@+id/messageDigitaleConfirmer"
        android:textColor="@color/black3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Touchez le capteur d'empreinte"
        android:gravity="center"
        />


</LinearLayout>