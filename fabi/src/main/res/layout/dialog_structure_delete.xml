<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/forme_white_vert_radius_10dp"
    android:padding="10dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="20dp">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/vector_rouge_desole" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Détachement"
            android:textSize="20dp"
            android:textColor="@color/black"
            android:fontFamily="@font/linux2"
            />
    </LinearLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Êtes-vous sûr de vouloir vous détacher de cette structure ?"
        android:layout_margin="10dp"
        android:gravity="center"
        android:layout_gravity="center"
        android:fontFamily="@font/linux2"
        android:textColor="@color/black2"
        android:textSize="15dp"
        />
    <EditText

        android:id="@+id/edit_text_dialog_struct_delete_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="20dp"
        android:textColor="@color/black3"
        android:background="@drawable/forme_white_radius_100dp_border_vert"
        android:hint="  Votre mot de passe"
        android:drawableStart="@drawable/vector_black3_password"
        android:inputType="textPassword"
        android:padding="7dp"
        android:selectAllOnFocus="false" />
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="end"
        android:layout_margin="10dp"
        >
        <TextView
            android:id="@+id/yes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oui"
            android:padding="10dp"
            android:textColor="@color/rouge"
            android:fontFamily="@font/linux2"
            android:layout_margin="10dp"
            android:textSize="20dp"/>
        <TextView
            android:id="@+id/no"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Non"
            android:layout_margin="10dp"
            android:padding="10dp"
            android:textColor="@color/purple_200"
            android:fontFamily="@font/linux2"
            android:textSize="20dp"
            />
    </LinearLayout>
</LinearLayout>