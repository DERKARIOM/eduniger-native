<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white3"
    tools:context=".controleur.activity.AudioPlayerActivity">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent" tools:context=".PlayActivity">
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:elevation="10dp"
            android:id="@+id/entete_play"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_marginTop="5dp"
            app:menu="@menu/toulbart_play"
            android:layout_height="wrap_content">
            <ImageView android:layout_width="50dp"
                android:id="@+id/list_music"
                android:background="@drawable/baseline_expand_more_24"
                android:layout_height="50dp"/>
            <LinearLayout android:layout_width="match_parent"
                android:orientation="horizontal"
                android:gravity="end"
                android:id="@+id/bloc"
                android:layout_height="wrap_content">
                <ImageView android:layout_width="45dp"
                    android:id="@+id/plaly"
                    android:background="@drawable/baseline_replay_circle_filled_24"
                    android:layout_height="45dp"/>
                <ImageView android:layout_width="45dp"
                    android:id="@+id/hout"
                    android:background="@drawable/baseline_volume_up_24"
                    android:layout_height="45dp"/>
                <ImageView android:layout_width="45dp"
                    android:id="@+id/anim"
                    android:background="@drawable/baseline_insert_chart_24"
                    android:layout_height="45dp"/>
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
        <RelativeLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/entete_play"
            android:id="@+id/miature">
            <ImageView android:id="@+id/logo"
                android:layout_width="230dp"
                android:layout_height="221dp"
                android:src="@drawable/baseline_music_note_24"
                android:layout_centerInParent="true"
                android:background="@drawable/background_play_music"/>
            <TextView android:id="@+id/titre_music"
                android:layout_below="@id/logo"
                android:layout_marginTop="100dp"
                android:textSize="20dp"
                android:textAlignment="center"
                android:padding="5dp"
                android:textColor="@color/black"
                android:text="5 Astuces pour gagner sa vie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView android:id="@+id/nom_play_list"
                android:layout_below="@id/titre_music"
                android:layout_marginTop="3dp"
                android:textSize="20dp"
                android:textAlignment="center"
                android:padding="5dp"
                android:textColor="@color/black"
                android:text="inconnu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:id="@+id/bloc1"
            android:layout_marginTop="50dp"
            android:layout_below="@id/miature"
            android:layout_height="wrap_content">
            <ImageView android:layout_width="45dp"
                android:id="@+id/bloc1_center"
                android:layout_centerInParent="true"
                android:background="@drawable/baseline_favorite_border_24"
                android:layout_height="45dp"/>
            <ImageView android:layout_width="45dp"
                android:id="@+id/bloc1_end"
                android:layout_centerInParent="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="20dp"
                android:background="@drawable/baseline_add_24"
                android:layout_height="45dp"/>

            <ImageView
                android:id="@+id/bloc1_left"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true"
                android:layout_marginStart="20dp"
                android:background="@drawable/baseline_bar_chart_24" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:id="@+id/bloc2"
            android:layout_below="@id/bloc1"
            android:layout_height="50dp">
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:layout_width="match_parent"
                android:theme="@style/Progretion"
                android:layout_marginEnd="40dp"
                android:layout_marginStart="40dp"
                android:layout_marginTop="20dp"
                android:id="@+id/play_progress"
                android:visibility="visible"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:23"
                android:layout_marginStart="40dp"
                android:layout_marginTop="5dp"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:layout_below="@id/play_progress"
                android:id="@+id/plqy_debut"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="31:49"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="5dp"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:layout_below="@id/play_progress"
                android:id="@+id/plqy_fin"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:id="@+id/bloc3"
            android:layout_marginTop="40dp"
            android:layout_below="@id/bloc2"
            android:layout_height="wrap_content">
            <ImageView android:layout_width="45dp"
                android:id="@+id/bloc3_center"
                android:layout_centerInParent="true"
                android:background="@drawable/baseline_play_arrow_24"
                android:layout_height="45dp"/>
            <ImageView android:layout_width="45dp"
                android:id="@+id/bloc3_list_all"
                android:layout_centerInParent="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="10dp"
                android:background="@drawable/baseline_text_rotation_none_24"
                android:layout_height="45dp"/>

            <ImageView
                android:id="@+id/bloc3_plus"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_centerInParent="true"
                android:layout_marginEnd="40dp"
                android:layout_toLeftOf="@id/bloc3_list_all"
                android:background="@drawable/baseline_fast_forward_24" />
            <ImageView android:layout_width="45dp"
                android:id="@+id/bloc3_moin"
                android:layout_centerInParent="true"
                android:layout_toEndOf="@id/bloc3_order"
                android:layout_marginStart="40dp"
                android:background="@drawable/baseline_fast_rewind_24"
                android:layout_height="45dp"/>

            <ImageView
                android:id="@+id/bloc3_order"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true"
                android:background="@drawable/baseline_shuffle_24" />
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>