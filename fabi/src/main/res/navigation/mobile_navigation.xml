<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.ninotech.fabi.controleur.fragment.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_structure"
        android:name="com.ninotech.fabi.controleur.fragment.StructureFragment"
        android:label="Structure"
        tools:layout="@layout/fragment_category" />

    <fragment
        android:id="@+id/navigation_suggestion"
        android:name="com.ninotech.fabi.controleur.fragment.SuggestionFragment"
        android:label="Suggestion"
        tools:layout="@layout/fragment_suggestion" />

    <fragment
        android:id="@+id/navigation_library"
        android:name="com.ninotech.fabi.controleur.fragment.LibraryFragment"
        android:label="Library"
        tools:layout="@layout/fragment_library" />
</navigation>