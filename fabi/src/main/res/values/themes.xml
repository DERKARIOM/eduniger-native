<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Le themes de base de l'application -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Couleur de la marque principale. -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/whiteVert</item>
        <!-- Couleur de la marque secondaire. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <!-- Couleur de la barre d'état. -->
        <item name="android:statusBarColor">@color/transparent</item>
    </style>
    <style name="background">
        <item name="background">@color/whiteVert</item>
    </style>
    <style name="activity_main_research">
        <item name="android:background">@drawable/forme_white_radius_10dp</item>
        <item name="android:drawableEnd">@drawable/vector_black3_micro</item>
    </style>
    <style name="activity_main_ico_notification">
        <item name="android:icon">@drawable/vector_black3_off_subscribe</item>
    </style>

    <style name="adapter_struture_btt">
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="progress_bar_wait" parent="@android:style/Widget.Holo.ProgressBar.Small">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:elevation">5dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:progressDrawable">@drawable/form_circular_bar_connexion</item>
    </style>
    <style name="MyApp.PSPDFKitTheme" parent="PSPDFKit.Theme.Default">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/purple_200</item>

        <!-- PSPDFKit comes with several styleable components. -->
    </style>

<!-- Le themes de formulaire(EditText) du type register et login -->
    <style name="edit_text_register">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">28dp</item>
        <item name="android:layout_marginEnd">28dp</item>
        <item name="android:layout_marginBottom">30dp</item>
        <item name="android:background">@drawable/forme_white_radius_10dp</item>
        <item name="android:elevation">10dp</item>
        <item name="android:padding">10dp</item>
    </style>

<!-- Le themes de message d' erreur du type register et login -->
    <style name="text_view_error_register">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerInParent">true</item>
        <item name="android:layout_marginBottom">20dp</item>
        <item name="android:text"></item>
        <item name="android:textColor">@color/rouge</item>
        <item name="android:textSize">@dimen/size_sub_title</item>
    </style>

<!--    Le themes de la bar de progression(ProgressBar) du type connexion -->
    <style name="progress_bar_connection" parent="@android:style/Widget.Holo.ProgressBar.Small">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:elevation">5dp</item>
        <item name="android:padding">20dp</item>
        <item name="android:visibility">invisible</item>
        <item name="android:progressDrawable">@drawable/form_circular_bar_connexion</item>
        <item name="android:layout_marginStart">40dp</item>
    </style>

    <style name="progress_bar_try_connection">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:visibility">visible</item>
        <item name="android:layout_marginStart">40dp</item>
    </style>

    <style name="progress_bar_try_connection2" parent="progress_bar_try_connection">
        <item name="android:layout_width">30dp</item>
        <item name="android:layout_height">30dp</item>
    </style>

<!--    Le themes du boutton(Button) de type connexion -->
    <style name="button_connexion">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerInParent">true</item>
        <item name="android:background">@drawable/form_purple_200_radius_10dp</item>
        <item name="android:text">@string/button_text_connection</item>
    </style>

    <style name="button_adhere">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">35dp</item>
        <item name="android:layout_centerInParent">true</item>
        <item name="android:background">@drawable/form_purple_200_radius_100dp</item>
        <item name="icon">@drawable/vector_black3_off_subscribe</item>
       <item name="iconGravity">textStart</item>
        <item name="android:text">@string/button_text_adhere</item>
    </style>

    <style name="button_pre_register">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerInParent">true</item>
        <item name="android:background">@drawable/form_purple_200_radius_10dp</item>
        <item name="android:text">Enregistrer</item>
    </style>

    <style name="web" parent="AppTheme">
        <item name="colorPrimary">@color/purple_200</item>
    </style>

<!--    Le themes de texte (TextView) de type login et register -->
    <style name="text_view_pass_login_register">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerHorizontal">true</item>
        <item name="android:padding">10dp</item>
        <item name="android:text">@string/text_view_pass_register_login</item>
        <item name="android:textSize">@dimen/size_title</item>
    </style>

<!--    Le themes wrap_content en larger et hauteur -->
    <style name="wrap_content_all">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <!--    Le themes match_parent en larger et hauteur -->
    <style name="match_parent_all">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <!--    Le themes pour avoir wrap_content en larger et match_parent en hauteur -->
    <style name="wrap_match">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <!--    Le themes pour avoir match_parent en larger et wrap_content en hauteur -->
    <style name="match_wrap">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    
    <!-- Le themes pour les icons de disponible des format -->
    <style name="icon_format">
        <item name="android:layout_width">10dp</item>
        <item name="android:layout_height">10dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:visibility">gone</item>
    </style>

    <!-- Le themes pour les icons des abonement -->
    <style name="icon_subcribe">
        <item name="android:layout_width">10dp</item>
        <item name="android:layout_height">10dp</item>
    </style>

    <!-- Le themes pour les nombres d' abonement -->
    <style name="icon_subcribe_text_view" parent="wrap_content_all">
        <item name="android:layout_marginStart">3dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textSize">@dimen/size_number_subcribe</item>
    </style>

    <style name="Dialog.fastpv" parent="android:Theme.Dialog" >
        <item name="colorPrimary">@color/dark</item>
    </style>
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/agrandir_dilog</item>
        <item name="android:windowExitAnimation">@anim/agrandir_dilog_out</item>
    </style>
    <style name="semeste">
        <item name="android:fontFamily">@font/apple2</item>
        <item name="android:textSize">20dp</item>
    </style>
    <style name="semeste2">
        <item name="android:fontFamily">@font/apple2</item>
        <item name="android:textSize">18dp</item>
    </style>
    <style name="ColorMatier">
        <item name="android:textColor">@color/black</item>
    </style>
    <style name="toolbar">
        <item name="android:textSize">25dp</item>
        <item name="android:fontFamily">@font/apple1</item>
    </style>
    <style name="Progretion">
        <item name="android:background">@drawable/forme_purple_200_radius_25dp</item>
    </style>
    <style name="ProgretionNote">
        <item name="android:background">@drawable/forme_white_radius_25dp</item>
    </style>
    <style name="Block_notif1">
        <item name="android:background">@drawable/forme_purple2_200_radius_10dp</item>
    </style>
    <style name="button_verify_connexion" parent="AppTheme">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerInParent">true</item>
        <item name="android:background">@color/white3</item>
    </style>
</resources>