<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Ras" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/transparente</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="Dialog.fastpv" parent="android:Theme.Dialog" >
        <item name="colorPrimary">@color/sombre</item>
    </style>
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/agrandir_dilog</item>
        <item name="android:windowExitAnimation">@anim/agrandir_dilog_out</item>
    </style>
    <style name="CircularBar" parent="@android:style/Widget.ProgressBar.Small">
        <item name="android:indeterminateDrawable">@drawable/circulaire_bar</item>
    </style>
    <style name="semeste">
        <item name="android:fontFamily">@font/apple2</item>
        <item name="android:textSize">20dp</item>
    </style>
    <style name="semeste2">
        <item name="android:fontFamily">@font/apple2</item>
        <item name="android:textSize">18dp</item>
    </style>
    <style name="ColorMatier">
        <item name="android:textColor">@color/black</item>
    </style>
    <style name="CustoTollbar">
        <item name="android:textSize">25dp</item>
        <item name="android:fontFamily">@font/apple1</item>
    </style>
    <style name="Progretion">
        <item name="android:background">@drawable/progretion</item>
    </style>
    <style name="ProgretionNote">
        <item name="android:background">@drawable/prgretion_notes</item>
    </style>
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:logo">@drawable/fast</item>
    </style>
    <style name="Block_notif1">
        <item name="android:background">@drawable/forme_purple2_200_radus_10dp</item>
    </style>
</resources>