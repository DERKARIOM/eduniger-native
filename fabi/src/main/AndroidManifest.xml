<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.REQUEST_LEGACY_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/img_default_livre"
        android:label="Fabi"
        android:logo="@drawable/img_default_livre"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ras"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <activity
            android:name="com.ninotech.fabi.controleur.activity.LivreLocalActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name="com.ninotech.fabi.controleur.activity.LivreActivity"
            android:screenOrientation="portrait"
            android:exported="false" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.CategorieActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName="com.ninotech.fabi.controleur.activity.MainActivity" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.LicenceActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="Licence" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.EmailChangeActivity"
            android:screenOrientation="portrait"
            android:exported="false" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.FingerPrintActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="Verrouillage par empreinte digitale"
            android:parentActivityName="com.ninotech.fabi.controleur.activity.ParametreActivity" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.InfosActivity"
            android:screenOrientation="portrait"
            android:exported="false" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.ChangePasswordActivity"
            android:screenOrientation="portrait"
            android:exported="false" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.ParametreActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="Parametres"
            android:parentActivityName="com.ninotech.fabi.controleur.activity.MainActivity" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.NotificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="Notification"
            android:parentActivityName="com.ninotech.fabi.controleur.activity.MainActivity" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.SuggestionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="Suggestion"
            android:parentActivityName="com.ninotech.fabi.controleur.activity.MainActivity" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="Inscrivez-vous" />
        <activity
            android:name="com.ninotech.fabi.controleur.activity.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:icon="@drawable/img_default_livre"
            android:label="Fabi"
            android:logo="@drawable/img_default_livre">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.ninotech.fabi.model.service.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <service
            android:name="com.ninotech.fabi.model.service.NotificationService"
            android:exported="false" />
    </application>

</manifest>