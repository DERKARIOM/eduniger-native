<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.REQUEST_LEGACY_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/item"
        android:label="fabi"
        android:logo="@drawable/item"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ras"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <provider
        android:name="androidx.core.content.FileProvider"
        android:authorities="${applicationId}.provider"
        android:exported="false"
        android:grantUriPermissions="true">
        <meta-data
            android:name="android.support.FILE_PROVIDER_PATHS"
            android:resource="@xml/file_paths" />
    </provider>
        <activity
            android:name="com.fabi.Controleur.LivreActivity"
            android:exported="false" />
        <activity
            android:name="com.fabi.Controleur.CategorieActivity"
            android:exported="false"
            android:parentActivityName="com.fabi.Controleur.MainActivity" />
        <activity
            android:name="com.fabi.Controleur.LicenceActivity"
            android:exported="false"
            android:label="Licence" />
        <activity
            android:name="com.fabi.Controleur.EmpreinteActivity"
            android:exported="false" />
        <activity
            android:name="com.fabi.Controleur.FingerPrintActivity"
            android:exported="false"
            android:label="Verrouillage par empreinte digitale"
            android:parentActivityName="com.fabi.Controleur.ParametreActivity" />
        <activity
            android:name="com.fabi.Controleur.EmailChangeActivity"
            android:exported="false" />
        <activity
            android:name="com.fabi.Controleur.InfosActivity"
            android:exported="false" />
        <activity
            android:name="com.fabi.Controleur.ChangePasswordActivity"
            android:exported="false" />
        <activity
            android:name="com.fabi.Controleur.ArchiverActivity"
            android:exported="false"
            android:label="Archiver"
            android:parentActivityName="com.fabi.Controleur.MainActivity" />
        <activity
            android:name="com.fabi.Controleur.ParametreActivity"
            android:exported="false"
            android:label="Parametres"
            android:parentActivityName="com.fabi.Controleur.MainActivity" />
        <activity
            android:name="com.fabi.Controleur.MessageImportantsActivity"
            android:exported="false"
            android:label="Message Importants"
            android:parentActivityName="com.fabi.Controleur.MainActivity" />
        <activity
            android:name="com.fabi.Controleur.SuggestionActivity"
            android:exported="false"
            android:label="Suggestion"
            android:parentActivityName="com.fabi.Controleur.MainActivity" />
        <activity
            android:name="com.fabi.Controleur.LoginActivity"
            android:exported="false"
            android:label="" />
        <activity
            android:name="com.fabi.Controleur.RegesterActivity"
            android:exported="false"
            android:label="Inscrivez-vous" />
        <activity
            android:name="com.fabi.Controleur.MainActivity"
            android:exported="true"
            android:icon="@drawable/item"
            android:label="fabi"
            android:logo="@drawable/item">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.fabi.Controleur.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <service
            android:name="com.fabi.Service.NoteService"
            android:exported="false" />
    </application>

</manifest>