<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/background"
    tools:context="com.ninotech.eduniger.controleur.activity.MainActivity">

    <include layout="@layout/toolbar_main"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/relative_layout_toolbar_search">

        <!-- Fragment principal -->
        <FrameLayout
            android:id="@+id/nav_host_fragment_activity_main"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Fond glassmorphism de la navbar -->
        <View
            android:id="@+id/backgroundView"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="60dp"
            android:layout_marginEnd="60dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="15dp"
            android:background="@drawable/bg_bottom_nav"
            android:minWidth="220dp" />

        <!-- Navbar flottante -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation_main"
            android:layout_width="wrap_content"
            style="@style/botton_navigation2"
            android:elevation="20dp"
            android:layout_height="45dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="15dp"
            app:menu="@menu/menu_bottom" />

        <!-- Bouton flottant IA -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_ai_assistant"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="75dp"
            android:elevation="25dp"
            android:contentDescription="Assistant IA"
            app:srcCompat="@drawable/ia_new"
            app:fabSize="normal"
            app:backgroundTint="?attr/colorPrimary"
            app:tint="@android:color/white"
            app:rippleColor="@android:color/white" />

    </FrameLayout>
</RelativeLayout>