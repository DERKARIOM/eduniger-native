<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/background"
    tools:context="com.ninotech.eduniger.controleur.activity.MainActivity">

    <include layout="@layout/toolbar_main"/>

    <!-- FrameLayout qui contient TOUT : fragment + navbar flottante -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/relative_layout_toolbar_search">

        <!-- Le fragment prend tout l'espace, y compris derrière la navbar -->
        <FrameLayout
            android:id="@+id/nav_host_fragment_activity_main"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:id="@+id/backgroundView"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="15dp"
            android:background="@drawable/bg_bottom_nav"
            android:minWidth="220dp" />

        <!-- Navbar par-dessus, fond transparent -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation_main"
            android:layout_width="wrap_content"
            style="@style/botton_navigation2"
            android:elevation="20dp"
            android:layout_height="50dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="15dp"
            app:menu="@menu/menu_bottom" />

    </FrameLayout>

</RelativeLayout>