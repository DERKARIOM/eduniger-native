<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/background"
    tools:context="com.ninotech.eduniger.controleur.fragment.HomeFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_fragment_recommended_wait"
        android:nestedScrollingEnabled="false"
        android:layout_margin="10dp"
        android:layout_centerInParent="true"
        style="@style/wrap_content_all" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll_view_fragment_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <RelativeLayout
                android:id="@+id/relative_layout_fragment_home"
                style="@style/match_parent_all">

                <!-- SLIDER PUB -->
                <!-- SLIDER PUB -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/view_pager_pub"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="5dp"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:clipToPadding="false"
                    android:elevation="6dp" />

                <!-- DOTS INDICATEUR -->
                <LinearLayout
                    android:id="@+id/layout_dots_pub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/view_pager_pub"
                    android:layout_centerHorizontal="true"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="6dp"/>

                <RelativeLayout
                    android:id="@+id/relative_layout_fragment_home_more_server"
                    android:layout_below="@id/layout_dots_pub"
                    android:visibility="gone"
                    style="@style/match_wrap">

                    <TextView
                        style="@style/wrap_content_all"
                        android:layout_marginStart="25dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_marginBottom="10dp"
                        android:text="Recommandé"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_view_server_more"
                        style="@style/wrap_content_all"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="25dp"
                        android:layout_marginBottom="10dp"
                        android:text="Voir plus"
                        android:layout_alignParentEnd="true"
                        android:textColor="@color/purple_200"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_fragment_home_server"
                    android:nestedScrollingEnabled="false"
                    android:layout_below="@id/relative_layout_fragment_home_more_server"
                    style="@style/match_parent_all" />

                <RelativeLayout
                    android:id="@+id/relative_layout_fragment_home_more_book"
                    android:layout_below="@id/recycler_view_fragment_home_server"
                    style="@style/match_wrap">

                    <TextView
                        style="@style/wrap_content_all"
                        android:layout_marginStart="25dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_marginBottom="10dp"
                        android:text="Recommandé"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_view_recommended_more"
                        style="@style/wrap_content_all"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="25dp"
                        android:layout_marginBottom="10dp"
                        android:text="Voir plus"
                        android:layout_alignParentEnd="true"
                        android:textColor="@color/purple_200"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_ranking"
                    android:nestedScrollingEnabled="false"
                    android:layout_margin="10dp"
                    android:layout_below="@id/relative_layout_fragment_home_more_book"
                    style="@style/match_parent_all" />

                <RelativeLayout
                    android:id="@+id/relative_layout_fragment_home_more_structure"
                    android:layout_below="@id/recycler_view_ranking"
                    style="@style/match_wrap">

                    <TextView
                        style="@style/wrap_content_all"
                        android:layout_marginStart="25dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_marginBottom="10dp"
                        android:text="Structures"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_view_recommended_more_structure"
                        style="@style/wrap_content_all"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="25dp"
                        android:layout_marginBottom="10dp"
                        android:text="Voir plus"
                        android:layout_alignParentEnd="true"
                        android:textColor="@color/purple_200"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_fragment_recommended_structure"
                    android:nestedScrollingEnabled="false"
                    android:layout_margin="10dp"
                    android:layout_below="@id/relative_layout_fragment_home_more_structure"
                    style="@style/match_parent_all" />

                <RelativeLayout
                    android:id="@+id/relative_layout_fragment_home_more_author"
                    android:layout_below="@id/recycler_view_fragment_recommended_structure"
                    style="@style/match_wrap">

                    <TextView
                        style="@style/wrap_content_all"
                        android:layout_marginStart="25dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_marginBottom="10dp"
                        android:text="Auteurs"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/text_view_recommended_more_author"
                        style="@style/wrap_content_all"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="25dp"
                        android:layout_marginBottom="10dp"
                        android:text="Voir plus"
                        android:layout_alignParentEnd="true"
                        android:textColor="@color/purple_200"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_author"
                    android:nestedScrollingEnabled="false"
                    android:layout_margin="10dp"
                    android:layout_below="@id/relative_layout_fragment_home_more_author"
                    style="@style/match_parent_all" />

            </RelativeLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</RelativeLayout>