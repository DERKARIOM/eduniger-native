<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/relative_layout_toolbar_search"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="25dp"
    android:layout_marginTop="20dp">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:layout_centerVertical="true"
        app:titleMarginStart="15dp"
        android:paddingStart="20dp"
        app:titleTextColor="@color/black3"
        app:menu="@menu/menu_home"
        android:layout_alignParentTop="true"
        app:titleTextAppearance="@style/toolbar"
        tools:ignore="RtlSymmetry" />
    <EditText
        android:id="@+id/edit_text_toolbar_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/activity_main_research"
        android:elevation="1dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="90dp"
        android:hint="  Rechercher un livre"
        android:drawableStart="?android:attr/actionModeWebSearchDrawable"
        android:inputType="text"
        android:layout_centerVertical="true"
        android:padding="8dp"
        android:focusable="false"
        android:selectAllOnFocus="false" />
    <ImageView
        android:id="@+id/image_view_toolbar_main_profile"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_margin="10dp"
        android:layout_centerVertical="true"
        android:src="@drawable/user"
        android:layout_alignParentEnd="true"
        />
</RelativeLayout>