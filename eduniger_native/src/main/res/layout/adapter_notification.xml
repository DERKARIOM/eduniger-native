<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/relative_layout_activity_notification"
        style="@style/notification_adapter_item"
        tools:ignore="UselessParent"
        android:elevation="5dp"
        android:padding="15dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">
        <RelativeLayout
            android:id="@+id/head"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/image_view_adapter_notification_icon"
                android:layout_margin="5dp"
                android:layout_width="20dp"
                android:visibility="gone"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/eduniger"
                android:contentDescription="@string/todo" />
            <TextView
                android:id="@+id/text_view_adapter_notification_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Alerte TELESAFE "
                android:textStyle="bold"
                android:layout_marginStart="7dp"
                android:layout_toRightOf="@id/image_view_adapter_notification_icon"
                android:textSize="@dimen/size_title"/>
            <TextView
                android:id="@+id/text_view_adapter_notification_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="il y'a 2 min"
                android:layout_centerVertical="true"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:gravity="end"
                android:layout_toRightOf="@id/text_view_adapter_notification_title"
                android:textSize="@dimen/size_sub_title"/>
        </RelativeLayout>
        <TextView
            android:id="@+id/text_view_adapter_notification_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/head"
            android:layout_marginTop="5dp"
            android:layout_marginStart="7dp"
            android:layout_marginEnd="7dp"
            android:text="La SIM de votre téléphone Samsung Galaxy Note8 a été changée."/>
    </RelativeLayout>
</RelativeLayout>